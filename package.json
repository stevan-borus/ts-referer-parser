{
  "name": "ts-referer-parser",
  "version": "1.0.9",
  "description": "A typed referer parser library",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "biome:lint": "biome lint --write .",
    "biome:format": "biome format --write .",
    "biome:check": "biome check .",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "typescript",
    "referer",
    "referrer",
    "parser"
  ],
  "author": "Stevan Borus",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stevan-borus/ts-referer-parser.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.5.0+sha256.e77bc3c5a9888f823fe061413f60ef02afad4b967c9b16b13458279473ba7d1c"
}
